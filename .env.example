# Copie para .env e preencha (não commite o .env)

# Telegram — recomendado para receber mensagens no celular
# 1) Fale com @BotFather no Telegram e crie um bot
# 2) Fale com @userinfobot para obter seu chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# E-mail (opcional)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=
